# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Sensitive variable files — NEVER commit these
terraform.tfvars
*.auto.tfvars
secrets.tfvars

# Backend config (contains bucket name / profile)
*.tfbackend

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS artefacts
.DS_Store
Thumbs.db

# Editor artefacts
.vscode/
.idea/
*.swp
*.swo
